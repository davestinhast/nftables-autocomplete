    "11-puertos-multiples-rangos-cidr.md"
    "12-ipv6.md"
    "13-contadores-monitorizacion.md"
    "14-familias-y-prioridades.md"
    "15-ruleset-completo-ejemplo.md"
    "__quickref__"
    "__exit__"
)

QUICKREF='# Comandos esenciales de nftables

## Ver reglas
```bash
sudo nft list ruleset                    # ver todo
sudo nft --handle list ruleset           # ver con numeros de regla
sudo nft list tables                     # solo las tablas
sudo nft list table inet filter          # una tabla en especifico
```

## Borrar reglas
```bash
sudo nft flush ruleset                   # borrar TODO
sudo nft delete rule inet filter input handle 18   # borrar regla especifica
sudo nft flush table inet filter         # vaciar una tabla
```

## Crear estructura basica
```bash
sudo nft add table inet filter
sudo nft add chain inet filter input '{ type filter hook input priority 0; policy drop; }'
sudo nft add rule inet filter input iif lo accept
sudo nft add rule inet filter input ct state established,related accept
sudo nft add rule inet filter input ct state invalid drop
```

## Reglas comunes
```bash
sudo nft add rule inet filter input tcp dport 22 accept          # SSH
sudo nft add rule inet filter input tcp dport { 80, 443 } accept # HTTP/S
sudo nft add rule inet filter input icmp type echo-request accept # ping
sudo nft add rule inet filter input ip saddr 1.2.3.4 drop        # bloquear IP
sudo nft add rule inet filter input tcp dport 22 limit rate 5/minute accept  # brute force
```

## Guardar
```bash
sudo nft list ruleset > /etc/nftables.conf
sudo systemctl enable nftables
sudo nft -f /etc/nftables.conf
```

## NAT rapido
```bash
sudo nft add table ip nat
sudo nft add chain ip nat postrouting '{ type nat hook postrouting priority 100; }'
sudo nft add rule ip nat postrouting oif eth0 masquerade
sudo sysctl -w net.ipv4.ip_forward=1
```

## Monitor en tiempo real
```bash
sudo nft monitor
sudo journalctl -k -f | grep "NFT"
```
'

# ─── MENU CON FZF ─────────────────────────────────────────────────────────────

menu_fzf() {
    local choice
    choice=$(printf '%s\n' "${MENU_LABELS[@]}" \
        | fzf \
            --prompt="  ¿Qué quieres ver? → " \
            --height=60% \
            --border=rounded \
            --color="fg:#cdd6f4,bg:#1e1e2e,hl:#cba6f7,fg+:#cdd6f4,bg+:#313244,hl+:#cba6f7" \
            --color="info:#89b4fa,prompt:#cba6f7,pointer:#f5c2e7,marker:#a6e3a1,spinner:#94e2d5" \
            --header="  nftables helper · ↑↓ para navegar · Enter para seleccionar · q para salir" \
            --preview-window=hidden \
            --no-sort \
        2>/dev/null) || return 1
    echo "$choice"
}

# ─── MENU CON SELECT (fallback sin fzf) ───────────────────────────────────────

menu_select() {
    echo -e "${BOLD}  ¿Qué quieres ver?${NC}"
    echo ""
    local i=1
    for label in "${MENU_LABELS[@]}"; do
        printf "  ${CYAN}%2d)${NC} %s\n" "$i" "$label"
        ((i++))
    done
    echo ""
    printf "  ${BOLD}Opcion:${NC} "
    local choice
    read -r choice
    # Validar numero
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#MENU_LABELS[@]} )); then
        echo "${MENU_LABELS[$((choice-1))]}"
    else
        echo ""
    fi
}

# ─── RESOLVER LABEL → ARCHIVO ─────────────────────────────────────────────────

resolve_file() {
    local label="$1"
    local i=0
    for lbl in "${MENU_LABELS[@]}"; do
        if [[ "$lbl" == "$label" ]]; then
            echo "${MENU_FILES[$i]}"
            return
        fi
        ((i++))
    done
    echo ""
}

# ─── LOOP PRINCIPAL ───────────────────────────────────────────────────────────

main() {
    banner

    while true; do
        local choice file

        if has fzf; then
            choice=$(menu_fzf) || { echo -e "\n  ${DIM}Hasta luego.${NC}\n"; exit 0; }
        else
            choice=$(menu_select)
        fi

        [[ -z "$choice" ]] && continue

        file=$(resolve_file "$choice")

        case "$file" in
            "__exit__")
                echo -e "\n  ${DIM}Hasta luego.${NC}\n"
                exit 0
                ;;
            "__quickref__")
                render_text "$QUICKREF"
                ;;
            "")
                echo -e "${YELLOW}  Opcion no reconocida.${NC}"
                ;;
            *)
                fetch_content "$file"
                ;;
        esac

        if ! has fzf; then
            echo ""
            echo -e "  ${DIM}Presiona Enter para volver al menu...${NC}"
            read -r
            banner
        else
            banner
        fi
    done
}

main "$@"
