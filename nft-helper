#!/usr/bin/env bash
# nft-helper — guia embebida de nftables, todo offline, todo inline

# ─── COLORES ──────────────────────────────────────────────────────────────────
B='\033[1m'       # bold
C='\033[0;36m'    # cyan
G='\033[0;32m'    # green
Y='\033[1;33m'    # yellow
D='\033[2m'       # dim
R='\033[0m'       # reset

# ─── RENDER INLINE ────────────────────────────────────────────────────────────
render() {
    local in_code=0
    while IFS= read -r line; do
        if [[ "$line" == '```'* ]]; then
            if (( in_code )); then
                in_code=0; echo -e "${R}"
            else
                in_code=1; echo -e "${G}"
            fi
            continue
        fi
        if (( in_code )); then
            echo "  $line"
        else
            case "$line" in
                '# '*)  echo -e "${B}${C}${line}${R}" ;;
                '## '*) echo -e "${B}${line}${R}" ;;
                '### '*) echo -e "${Y}${line}${R}" ;;
                '---')  echo -e "${D}────────────────────────────────────────${R}" ;;
                '| '*)  echo -e "${D}${line}${R}" ;;
                *)      echo "$line" ;;
            esac
        fi
    done
    echo -e "${R}"
}

