#!/usr/bin/env bash
# nft-helper — Ayuda interactiva de nftables basada en NFTABLES-Examn
# Repo: https://github.com/davestinhast/NFTABLES-Examn
#
# Uso: ./nft-helper
#      nft-helper          (si esta en $PATH)

set -euo pipefail

# ─── CONFIGURACION ────────────────────────────────────────────────────────────

REPO_OWNER="davestinhast"
REPO_NAME="NFTABLES-Examn"
RAW_BASE="https://raw.githubusercontent.com/${REPO_OWNER}/${REPO_NAME}/main/comandos"

# Buscar repo local en orden de preferencia
LOCAL_REPO=""
for candidate in \
    "$HOME/NFTABLES-Examn" \
    "$HOME/Documents/NFTABLES-Examn" \
    "$(dirname "$0")/../NFTABLES-Examn" \
    "/opt/NFTABLES-Examn"
do
    if [[ -d "$candidate/comandos" ]]; then
        LOCAL_REPO="$candidate"
        break
    fi
done

# ─── COLORES ──────────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ─── UTILIDADES ───────────────────────────────────────────────────────────────

has() { command -v "$1" &>/dev/null; }

render_md() {
    local file="$1"
    if has batcat; then
        batcat --language=md --style=plain --paging=always --color=always "$file" 2>/dev/null \
            || cat "$file"
    elif has bat; then
        bat --language=md --style=plain --paging=always --color=always "$file" 2>/dev/null \
            || cat "$file"
    elif has glow; then
        glow "$file"
    else
        # Fallback: resaltar codigo bash manualmente
        less -R "$file"
    fi
}

render_text() {
    local text="$1"
    local tmpfile
    tmpfile=$(mktemp /tmp/nft-helper-XXXXXX.md)
    echo "$text" > "$tmpfile"
    render_md "$tmpfile"
    rm -f "$tmpfile"
}

fetch_content() {
    local slug="$1"   # ej: 01-instalacion.md
    local tmpfile

    if [[ -n "$LOCAL_REPO" ]]; then
        render_md "$LOCAL_REPO/comandos/$slug"
        return
    fi

    # Sin repo local → bajar de GitHub
    tmpfile=$(mktemp /tmp/nft-helper-XXXXXX.md)
    if has curl; then
        curl -fsSL "${RAW_BASE}/${slug}" -o "$tmpfile" 2>/dev/null \
            && render_md "$tmpfile" \
            || echo -e "${RED}No se pudo descargar el contenido. Verifica tu conexion.${NC}"
    elif has wget; then
        wget -qO "$tmpfile" "${RAW_BASE}/${slug}" 2>/dev/null \
            && render_md "$tmpfile" \
            || echo -e "${RED}No se pudo descargar el contenido. Verifica tu conexion.${NC}"
    else
        echo -e "${RED}Necesitas curl o wget para bajar contenido sin repo local.${NC}"
    fi
    rm -f "$tmpfile"
}

banner() {
    clear
    echo -e "${CYAN}${BOLD}"
    echo "  ███╗   ██╗███████╗████████╗ █████╗ ██████╗ ██╗     ███████╗███████╗"
    echo "  ████╗  ██║██╔════╝╚══██╔══╝██╔══██╗██╔══██╗██║     ██╔════╝██╔════╝"
    echo "  ██╔██╗ ██║█████╗     ██║   ███████║██████╔╝██║     █████╗  ███████╗"
    echo "  ██║╚██╗██║██╔══╝     ██║   ██╔══██║██╔══██╗██║     ██╔══╝  ╚════██║"
    echo "  ██║ ╚████║██║        ██║   ██║  ██║██████╔╝███████╗███████╗███████║"
    echo "  ╚═╝  ╚═══╝╚═╝        ╚═╝   ╚═╝  ╚═╝╚═════╝ ╚══════╝╚══════╝╚══════╝"
    echo -e "${NC}"
    echo -e "  ${DIM}Ayuda interactiva · github.com/${REPO_OWNER}/${REPO_NAME}${NC}"
    if [[ -n "$LOCAL_REPO" ]]; then
        echo -e "  ${GREEN}✓ Repo local encontrado:${NC} ${DIM}$LOCAL_REPO${NC}"
    else
        echo -e "  ${YELLOW}⚡ Modo online — sin repo local, bajando de GitHub${NC}"
        echo -e "  ${DIM}  Para modo offline: git clone https://github.com/${REPO_OWNER}/${REPO_NAME} ~/NFTABLES-Examn${NC}"
    fi
    echo ""
}

# ─── OPCIONES DEL MENU ────────────────────────────────────────────────────────

declare -a MENU_LABELS=(
    "📦  Instalacion y manejo del servicio"
    "📋  Ver, borrar y editar reglas"
    "🗂   Tablas y cadenas"
    "🔥  Reglas de firewall comunes (SSH, HTTP, IPs, ping)"
    "🚫  Sets y lista negra de IPs"
