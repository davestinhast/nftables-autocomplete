#!/usr/bin/env bash
# nft-helper — guia embebida de nftables, offline, inline
# Uso:
#   nft-helper              → menu interactivo
#   nft-helper <1-17>       → tema directo
#   nft-helper s <palabra>  → buscar en todos los temas

# ─── COLORES ──────────────────────────────────────────────────────────────────
BLD='\033[1m'
CYN='\033[0;36m'
GRN='\033[0;32m'
YLW='\033[1;33m'
RED='\033[0;31m'
DIM='\033[2m'
UND='\033[4m'
RST='\033[0m'

# ─── RENDER ───────────────────────────────────────────────────────────────────
render() {
    local in_code=0
    while IFS= read -r line; do
        if [[ "$line" == '```'* ]]; then
            if (( in_code )); then
                in_code=0
                echo -e "${RST}"
            else
                in_code=1
                echo -e "${GRN}"
            fi
            continue
        fi
        if (( in_code )); then
            printf "  %s\n" "$line"
        else
            case "$line" in
                '# '*)
                    echo ""
                    echo -e "${BLD}${CYN}${line#\# }${RST}"
                    echo -e "${DIM}$(printf '─%.0s' {1..50})${RST}"
                    ;;
                '## '*)
                    echo ""
                    echo -e "${BLD}${YLW}▶  ${line#\#\# }${RST}"
                    ;;
                '### '*)
                    echo -e "${BLD}   ${line#\#\#\# }${RST}"
                    ;;
                '---')
                    echo -e "${DIM}$(printf '┄%.0s' {1..50})${RST}"
                    ;;
                '| '*)
                    echo -e "${DIM}${line}${RST}"
                    ;;
                '')
                    echo ""
                    ;;
                *)
                    echo "  $line"
                    ;;
            esac
        fi
    done
    echo -e "${RST}"
}

# ─── CONTENIDO ────────────────────────────────────────────────────────────────

