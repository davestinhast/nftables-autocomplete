    local term="${1,,}"   # lowercase
    local found=0

    declare -a fns=(t0 t1 t2 t3 t4 t5 t6 t7 t8 t9 t10 t11 t12 t13 t14 t15 t16)
    declare -a names=(
        "Resumen examen" "Instalacion" "Ver/borrar reglas" "Tablas y cadenas"
        "Firewall comun" "Sets/blacklist" "Persistencia" "Conntrack"
        "Output/Forward" "Reject/Drop/Log" "NAT" "Puertos/rangos/CIDR"
        "IPv6" "Contadores" "Familias/hooks" "Ruleset completo" "Referencia rapida"
    )

    echo ""
    echo -e "${BLD}${CYN}Buscando: ${YLW}${term}${RST}"
    echo -e "${DIM}$(printf '─%.0s' {1..50})${RST}"
    echo ""

    for i in "${!fns[@]}"; do
        local content
        content=$("${fns[$i]}" 2>/dev/null)
        if echo "$content" | grep -qi "$term" 2>/dev/null; then
            echo -e "  ${GRN}✓${RST} ${BLD}${i})${RST}  ${names[$i]}"
            found=1
        fi
    done

    if (( ! found )); then
        echo -e "  ${RED}Sin resultados para '${term}'${RST}"
    fi
    echo ""
}

# ─── MENU ─────────────────────────────────────────────────────────────────────

MENU=(
    " 0  RESUMEN EXAMEN — lo que cae seguro"
    " 1  Instalacion y servicio"
    " 2  Ver, borrar y editar reglas"
    " 3  Tablas y cadenas"
    " 4  Reglas de firewall (SSH, HTTP, IPs, ping)"
    " 5  Sets y lista negra de IPs"
    " 6  Guardar la configuracion"
    " 7  Firewall stateful — conntrack"
    " 8  Cadenas OUTPUT y FORWARD"
    " 9  REJECT vs DROP y logging"
    "10  NAT — DNAT, SNAT y Masquerade"
    "11  Puertos multiples, rangos y CIDR"
    "12  IPv6"
    "13  Contadores y monitoreo"
    "14  Familias, hooks y prioridades"
    "15  Ruleset completo de ejemplo"
    "16  Referencia rapida"
    " s  Buscar  (ej: s masquerade)"
    " q  Salir"
)

show_menu() {
    echo ""
    echo -e "  ${BLD}${CYN}nftables helper${RST}  ${DIM}— elige un tema o busca con s <palabra>${RST}"
    echo ""
    for line in "${MENU[@]}"; do
        echo -e "    ${DIM}${line}${RST}"
    done
    echo ""
}

run_topic() {
    case "$1" in
        0)  t0  ;;
        1)  t1  ;;
        2)  t2  ;;
        3)  t3  ;;
        4)  t4  ;;
        5)  t5  ;;
        6)  t6  ;;
        7)  t7  ;;
        8)  t8  ;;
        9)  t9  ;;
        10) t10 ;;
        11) t11 ;;
        12) t12 ;;
        13) t13 ;;
        14) t14 ;;
        15) t15 ;;
        16) t16 ;;
    esac
}

# ─── ENTRADA DIRECTA ──────────────────────────────────────────────────────────
# nft-helper 7         → tema directo
# nft-helper s ssh     → busqueda directa

if [[ -n "${1:-}" ]]; then
    if [[ "${1}" == "s" || "${1}" == "search" ]]; then
        search_topics "${2:-}"
    elif [[ "$1" =~ ^[0-9]+$ ]] && (( 10#$1 >= 0 && 10#$1 <= 16 )); then
        run_topic "$1"
    else
        echo -e "${RED}Uso: nft-helper [0-16] | s <palabra>${RST}"
    fi
    exit 0
fi

# ─── LOOP INTERACTIVO ─────────────────────────────────────────────────────────
while true; do
    show_menu
    printf "  ${BLD}>${RST} "
    read -r input

    first="${input%% *}"
    rest="${input#* }"

    case "$first" in
        q|Q) echo ""; break ;;
        s|S) search_topics "$rest" ;;
        ''|*[^0-9]*)
            [[ -z "$first" ]] && continue
            echo -e "${RED}  opcion no valida${RST}"
            ;;
        *)
            if (( 10#$first >= 0 && 10#$first <= 16 )); then
                echo ""
                run_topic "$first"
            else
                echo -e "${RED}  numero fuera de rango (0-16)${RST}"
            fi
            ;;
    esac
done
